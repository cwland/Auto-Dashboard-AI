{
  "manifest_version": 3,
  "name": "Auto Dashboard AI",
  "version": "1.3.0",
  "_comment_key": "Pins the extension ID to the same value on every device so the dashboard's chrome-extension:// URL (e.g. for the Home button) is identical across synced computers. Resulting ID: laaaekkkcndolobpejoknmhgjljbmcdi",
  "key": "",
  "description": "Auto-generate beautiful dashboards from your bookmarks with AI-powered descriptions and icons.",
  "permissions": ["bookmarks", "storage", "favicon", "alarms"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Auto Dashboard AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
